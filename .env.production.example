# =====================================================================
# Vercel 프로덕션 환경변수 체크리스트
# ---------------------------------------------------------------------
# 이 파일은 "Vercel에 뭘 등록해야 하는지" 안내용 템플릿입니다.
# 실제 값을 채우지 마세요. 실제 값은 Vercel 콘솔(또는 CLI)에 등록합니다.
#
# 등록 방법 2가지
#   A) Vercel 대시보드 → 프로젝트 → Settings → Environment Variables
#      각 키마다 값 입력 + Production/Preview/Development 체크
#   B) Vercel CLI
#      vercel link
#      vercel env add DATABASE_URL production
#      (프롬프트에서 값 붙여넣기 — 채팅·문서엔 절대 X)
# =====================================================================

# ---------------------------------------------------------------------
# Neon (Postgres) — Vercel Marketplace에서 Neon 통합하면 자동 주입
# ---------------------------------------------------------------------
DATABASE_URL=                              # 풀러 URL (앱 런타임)
DATABASE_URL_UNPOOLED=                     # 직접 연결 (마이그레이션·워커용)

# ---------------------------------------------------------------------
# Auth.js v5 — 직접 등록 필요
# ---------------------------------------------------------------------
AUTH_SECRET=                               # `openssl rand -hex 32`로 생성한 32바이트 hex
# AUTH_URL은 등록하지 마세요. Vercel이 배포 도메인을 자동 주입합니다.
# AUTH_TRUST_HOST=true                     # 커스텀 도메인 + Edge 미들웨어 쓰면 추가

# 소셜 로그인 (Phase 2 이후 활성화 시)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_ZALO_ID=
# AUTH_ZALO_SECRET=

# ---------------------------------------------------------------------
# Cloudflare R2 (오디오) — 직접 등록 필요
# ---------------------------------------------------------------------
R2_ACCOUNT_ID=                             # Cloudflare 대시보드 → R2 → Account ID
R2_ACCESS_KEY_ID=                          # R2 API Token (Object R/W, 버킷 scope)
R2_SECRET_ACCESS_KEY=                      # 위 토큰의 Secret
R2_BUCKET=danang-academy-audio             # 실제 버킷 이름

# ---------------------------------------------------------------------
# AI providers — 직접 등록 (워커가 사용 중이면 워커 머신에도 동일 키)
# ---------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------
# 사이트
# ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://danang-academy.vercel.app   # 실제 배포 도메인으로 교체
TZ=Asia/Ho_Chi_Minh

# ---------------------------------------------------------------------
# 개발용 토글 (프로덕션에선 끄기)
# ---------------------------------------------------------------------
# MOCK_AI_WORKER=                          # AI 워커 연결되면 등록 X (또는 false)
# MOCK_R2_UPLOAD=                          # R2 정상 동작 후 등록 X (또는 false)
