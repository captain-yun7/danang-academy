# Neon (Postgres)
# Vercel Marketplace의 Neon 통합 시 자동 주입됨
DATABASE_URL=                              # 풀러 경유 (앱 런타임용)
DATABASE_URL_UNPOOLED=                     # 직접 연결 (마이그레이션·일회성 작업용)

# Auth.js v5 (NextAuth)
AUTH_SECRET=                               # `openssl rand -hex 32` 로 생성
AUTH_URL=http://localhost:3000             # 프로덕션은 Vercel이 자동 주입
# 소셜 로그인 (필요 시 추가)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_ZALO_ID=                            # Zalo Open Platform OAuth
# AUTH_ZALO_SECRET=

# Vercel Blob (오디오 파일)
BLOB_READ_WRITE_TOKEN=                     # 서버에서 signed upload URL 발급용

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
TZ=Asia/Ho_Chi_Minh
